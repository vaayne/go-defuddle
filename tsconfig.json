{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": false,
		"sourceMap": false,
		"ignoreDeprecations": "6.0"
	},
	"include": [
		"defuddle/src/**/*.ts",
		"internal/js/**/*.js"
	]
}
